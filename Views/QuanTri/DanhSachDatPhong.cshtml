@model List<DatPhong>
@{
    ViewData["Title"] = "Quản lý đặt phòng";
}

<section class="admin-section">
    <div class="container-custom">
        <div class="admin-header">
            <h1><i class="bi bi-calendar-check-fill"></i> Quản lý đặt phòng</h1>
            <div class="admin-nav">
                <a href="/QuanTri" class="admin-nav-link"><i class="bi bi-speedometer2"></i> Dashboard</a>
                <a href="/QuanTri/DanhSachPhong" class="admin-nav-link"><i class="bi bi-house"></i> Phòng</a>
                <a href="/QuanTri/DanhSachKhungGio" class="admin-nav-link"><i class="bi bi-clock"></i> Khung giờ</a>
                <a href="/QuanTri/DanhSachDatPhong" class="admin-nav-link active"><i class="bi bi-calendar-check"></i> Đặt phòng</a>
                <a href="/QuanTri/DanhSachKhuVuc" class="admin-nav-link"><i class="bi bi-geo-alt"></i> Khu vực</a>
                <a href="/QuanTri/GiaVaKhuyenMai" class="admin-nav-link"><i class="bi bi-tag"></i> Giá & KM</a>
                <a href="/QuanTri/CaiDat" class="admin-nav-link"><i class="bi bi-gear"></i> Cài đặt</a>
                <a href="/QuanTri/QuanLyTaiKhoan" class="admin-nav-link"><i class="bi bi-people"></i> Tài khoản</a>
                <a href="/TaiKhoan/DangXuat" class="admin-nav-link logout"><i class="bi bi-box-arrow-right"></i> Đăng xuất</a>
            </div>
        </div>

        <div class="admin-card">
            <div class="card-header-flex">
                <div class="filter-tabs">
                    <a href="/QuanTri/DanhSachDatPhong" class="filter-tab @(ViewBag.TrangThai == null ? "active" : "")">Tất cả</a>
                    <a href="/QuanTri/DanhSachDatPhong?trangThai=ChoXacNhan" class="filter-tab @(ViewBag.TrangThai == "ChoXacNhan" ? "active" : "")">Chờ xác nhận</a>
                    <a href="/QuanTri/DanhSachDatPhong?trangThai=DaXacNhan" class="filter-tab @(ViewBag.TrangThai == "DaXacNhan" ? "active" : "")">Đã xác nhận</a>
                    <a href="/QuanTri/DanhSachDatPhong?trangThai=DaHuy" class="filter-tab @(ViewBag.TrangThai == "DaHuy" ? "active" : "")">Đã hủy</a>
                    <a href="/QuanTri/DanhSachDatPhong?trangThai=DaHetHan" class="filter-tab @(ViewBag.TrangThai == "DaHetHan" ? "active" : "")" style="color:#9e9e9e;">Hết hạn</a>
                </div>
                <a href="/QuanTri/TaoDatPhong" class="btn-primary-custom btn-sm"><i class="bi bi-plus-circle"></i> Tạo đặt phòng</a>
            </div>

            <div class="table-responsive">
                <table class="table-custom">
                    <thead>
                        <tr>
                            <th>Mã ĐP</th>
                            <th>Khách hàng</th>
                            <th>Email</th>
                            <th>SĐT</th>
                            <th>Phòng</th>
                            <th>Ngày nhận</th>
                            <th>Tổng tiền</th>
                            <th>Nguồn</th>
                            <th>Trạng thái</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dp in Model)
                        {
                            <tr>
                                <td><strong>@dp.MaDatPhong</strong></td>
                                <td>@dp.TenKhach</td>
                                <td>@dp.Email</td>
                                <td>@dp.SoDienThoai</td>
                                <td>@dp.Phong?.TenPhong</td>
                                <td>@dp.NgayNhanPhong.ToString("dd/MM")</td>
                                <td>@dp.TongTien.ToString("N0")đ</td>
                                <td>
                                    @switch (dp.NguonDat)
                                    {
                                        case "Web": <span class="source-badge source-web"><i class="bi bi-globe"></i></span> break;
                                        case "Messenger": <span class="source-badge source-messenger"><i class="bi bi-messenger"></i></span> break;
                                        case "Zalo": <span class="source-badge source-zalo"><i class="bi bi-chat-dots"></i></span> break;
                                    }
                                </td>
                                <td>
                                    @switch (dp.TrangThai)
                                    {
                                        case "ChoXacNhan": <span class="status-badge status-pending">Chờ XN</span> break;
                                        case "DaXacNhan": <span class="status-badge status-confirmed">Đã XN</span> break;
                                        case "DaNhanPhong": <span class="status-badge status-checkin">Đã nhận</span> break;
                                        case "HoanThanh": <span class="status-badge status-done">Hoàn thành</span> break;
                                        case "DaHuy": <span class="status-badge status-cancel">Đã hủy</span> break;
                                        case "DaHetHan": <span class="status-badge" style="background:rgba(158,158,158,0.15);color:#9e9e9e;">⏰ Hết hạn</span> break;
                                    }
                                </td>
                                <td>
                                    <div class="action-btns">
                                        <a href="/QuanTri/ChiTietDatPhong/@dp.Id" class="btn-icon" title="Chi tiết"><i class="bi bi-eye"></i></a>
                                        @if (dp.TrangThai == "ChoXacNhan")
                                        {
                                            <button onclick="xacNhan(@dp.Id)" class="btn-icon btn-icon-success" title="Xác nhận"><i class="bi bi-check-circle"></i></button>
                                            <button onclick="huyDon(@dp.Id)" class="btn-icon btn-icon-danger" title="Hủy"><i class="bi bi-x-circle"></i></button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
function xacNhan(id) {
    showConfirm('✅', 'Xác nhận đặt phòng', 'Bạn có chắc muốn xác nhận đơn này?', function() {
        fetch('/QuanTri/XacNhanDatPhong', { method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'}, body: 'id=' + id })
            .then(r => r.json())
            .then(d => { if (d.success) { showSuccess('Đã xác nhận!', 'Mã mở cửa: <strong>' + d.maMoCua + '</strong>'); setTimeout(function(){ location.reload(); }, 1500); } });
    });
}
function huyDon(id) {
    showConfirm('🗑️', 'Hủy đặt phòng', 'Bạn có chắc muốn hủy đơn này?', function() {
        fetch('/QuanTri/HuyDatPhong', { method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'}, body: 'id=' + id })
            .then(r => r.json())
            .then(d => { if (d.success) { showSuccess('Đã hủy!', 'Đơn đã được hủy.'); setTimeout(function(){ location.reload(); }, 1500); } });
    });
}
</script>
}
