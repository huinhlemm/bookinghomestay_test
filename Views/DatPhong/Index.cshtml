@model DatPhongViewModel
@{
    ViewData["Title"] = "Đặt phòng - " + Model.TenPhong;
}

<section class="page-header">
    <div class="container-custom">
        <h1><i class="bi bi-calendar-check-fill"></i> Đặt phòng</h1>
        <p>@Model.TenPhong</p>
    </div>
</section>

<section class="booking-section">
    <div class="container-custom">
        <div class="booking-grid">
            <!-- Left: Timeline -->
            <div class="booking-timeline">
                <div class="booking-date-picker">
                    <label><i class="bi bi-calendar3"></i> Chọn ngày</label>
                    <div class="date-picker-wrap">
                        <input type="text" id="ngayDat" class="input-custom" 
                               value="@Model.NgayNhanPhong.ToString("dd-MM-yyyy")" 
                               readonly style="cursor:pointer;font-weight:600;font-size:1rem;" />
                    </div>
                </div>

                <h3><i class="bi bi-clock-fill"></i> Chọn khung giờ</h3>
                <div class="timeline-grid" id="timelineGrid">
                    @{
                        var isToday = Model.NgayNhanPhong.Date == DateTime.Today;
                        var currentTime = DateTime.Now.TimeOfDay;
                    }
                    @foreach (var kg in Model.DanhSachKhungGio)
                    {
                        var daQuaGio = isToday && kg.KhungGio.GioBatDau < currentTime;
                        var trangThaiClass = daQuaGio ? "slot-expired" : (kg.DaDat ? "slot-booked" : "slot-available");
                        <div class="timeline-slot @trangThaiClass" 
                             data-id="@kg.KhungGio.Id" 
                             data-gia="@kg.Gia"
                             data-da-dat="@(kg.DaDat || daQuaGio ? "true" : "false")"
                             data-gio-bat-dau="@kg.KhungGio.GioBatDau.ToString(@"hh\:mm")"
                             data-gio-ket-thuc="@kg.KhungGio.GioKetThuc.ToString(@"hh\:mm")"
                             onclick="chonKhungGio(this)">
                            <div class="slot-emoji">@kg.KhungGio.BieuTuong</div>
                            <div class="slot-name">@kg.KhungGio.TenKhungGio</div>
                            <div class="slot-time">@kg.KhungGio.GioBatDau.ToString(@"hh\:mm") – @kg.KhungGio.GioKetThuc.ToString(@"hh\:mm")</div>
                            <div class="slot-price">@kg.Gia.ToString("N0")đ</div>
                            @if (daQuaGio)
                            {
                                <div class="slot-status" style="color:#e53935;"><i class="bi bi-clock-history"></i> Đã qua giờ</div>
                            }
                            else if (kg.DaDat)
                            {
                                <div class="slot-status"><i class="bi bi-x-circle-fill"></i> Đã đặt</div>
                            }
                            else
                            {
                                <div class="slot-status"><i class="bi bi-check-circle"></i> Trống</div>
                            }
                        </div>
                    }
                </div>

                <div class="slot-legend">
                    <span><span class="legend-dot available"></span> Trống</span>
                    <span><span class="legend-dot selected"></span> Đang chọn</span>
                    <span><span class="legend-dot booked"></span> Đã đặt</span>
                </div>
            </div>

            <!-- Right: Booking Form -->
            <div class="booking-form-wrap">
                <div class="booking-summary" id="bookingSummary">
                    <h3><i class="bi bi-cart-fill"></i> Tóm tắt đặt phòng</h3>
                    <div class="summary-room">
                        <strong>@Model.TenPhong</strong>
                        <small>@Model.ThongTinPhong?.DiaChi</small>
                    </div>
                    <div class="summary-date">
                        <i class="bi bi-calendar3"></i> <span id="summaryDate">@Model.NgayNhanPhong.ToString("dd-MM-yyyy")</span>
                    </div>
                    <div class="summary-slots" id="summarySlots">
                        <p class="text-muted">Chưa chọn khung giờ</p>
                    </div>
                    <div class="summary-total">
                        <span>Tổng tiền:</span>
                        <span class="total-amount" id="tongTien">0đ</span>
                    </div>
                </div>

                <form asp-controller="DatPhong" asp-action="TaoDatPhong" method="post" id="datPhongForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="MaPhong" value="@Model.MaPhong" />
                    <input type="hidden" name="NgayNhanPhong" id="formNgay" value="@Model.NgayNhanPhong.ToString("yyyy-MM-dd")" />
                    <div id="hiddenKhungGio"></div>

                    <div class="form-group-custom">
                        <label><i class="bi bi-person-fill"></i> Tên khách *</label>
                        <input type="text" name="TenKhach" class="input-custom" required placeholder="Nhập tên khách" id="inputTenKhach" />
                    </div>
                    <div class="form-group-custom">
                        <label><i class="bi bi-telephone-fill"></i> Số điện thoại *</label>
                        <input type="tel" name="SoDienThoai" class="input-custom" required placeholder="Nhập số điện thoại" id="inputSDT" />
                    </div>
                    <div class="form-group-custom">
                        <label><i class="bi bi-envelope-fill"></i> Email *</label>
                        <input type="email" name="Email" class="input-custom" required placeholder="Nhập email để nhận thông tin đặt phòng" />
                    </div>
                    <div class="form-group-custom">
                        <label><i class="bi bi-chat-left-text-fill"></i> Ghi chú</label>
                        <textarea name="GhiChu" class="input-custom" rows="2" placeholder="Ghi chú thêm..."></textarea>
                    </div>

                    <!-- CCCD Upload -->
                    <div class="form-group-custom">
                        <label><i class="bi bi-person-badge-fill"></i> CCCD / CMND mặt trước *</label>
                        <input type="hidden" name="CccdMatTruoc" id="cccdTruocInput" />
                        <div style="display:flex;align-items:center;gap:10px;">
                            <img id="cccdTruocPreview" src="" style="display:none;width:120px;height:75px;object-fit:cover;border-radius:8px;border:2px solid var(--border);" />
                            <label style="cursor:pointer;background:var(--bg-surface);border:2px dashed var(--border);padding:12px 16px;border-radius:10px;font-size:13px;display:inline-flex;align-items:center;gap:6px;transition:all .2s;">
                                <i class="bi bi-cloud-arrow-up" style="font-size:18px;"></i> Chọn ảnh mặt trước
                                <input type="file" accept="image/*" style="display:none;" onchange="uploadCCCD(this,'cccdTruocInput','cccdTruocPreview','statusCccdTruoc')" />
                            </label>
                            <span id="statusCccdTruoc" style="font-size:12px;"></span>
                        </div>
                    </div>
                    <div class="form-group-custom">
                        <label><i class="bi bi-person-badge"></i> CCCD / CMND mặt sau *</label>
                        <input type="hidden" name="CccdMatSau" id="cccdSauInput" />
                        <div style="display:flex;align-items:center;gap:10px;">
                            <img id="cccdSauPreview" src="" style="display:none;width:120px;height:75px;object-fit:cover;border-radius:8px;border:2px solid var(--border);" />
                            <label style="cursor:pointer;background:var(--bg-surface);border:2px dashed var(--border);padding:12px 16px;border-radius:10px;font-size:13px;display:inline-flex;align-items:center;gap:6px;transition:all .2s;">
                                <i class="bi bi-cloud-arrow-up" style="font-size:18px;"></i> Chọn ảnh mặt sau
                                <input type="file" accept="image/*" style="display:none;" onchange="uploadCCCD(this,'cccdSauInput','cccdSauPreview','statusCccdSau')" />
                            </label>
                            <span id="statusCccdSau" style="font-size:12px;"></span>
                        </div>
                    </div>

                    <!-- Xác nhận điều khoản -->
                    <div class="form-group-custom" style="background:rgba(255,90,95,0.08);border:1px solid rgba(255,90,95,0.2);border-radius:12px;padding:14px;">
                        <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;margin:0;">
                            <input type="checkbox" id="chkXacNhan" style="margin-top:4px;width:18px;height:18px;accent-color:var(--primary);" />
                            <span style="font-size:13px;line-height:1.5;">
                                <strong style="color:var(--primary);">Xác nhận:</strong> Tôi xác nhận mọi người trong nhóm đã đủ tuổi vị thành niên (từ 18 tuổi trở lên), đồng ý rời khỏi phòng và <strong>không được hoàn tiền</strong> nếu có dấu hiệu tệ nạn xã hội.
                            </span>
                        </label>
                    </div>

                    <button type="submit" class="btn-primary-custom btn-block" id="btnDatPhong" disabled>
                        <i class="bi bi-check-circle-fill"></i> Xác nhận đặt phòng
                    </button>
                </form>

                <!-- Chat booking -->
                <div class="chat-booking-section">
                    <p class="chat-booking-label">Hoặc đặt qua chat:</p>
                    <div class="chat-booking-btns">
                        <button onclick="datQuaChat('messenger')" class="btn-messenger" id="btnMessenger">
                            <i class="bi bi-messenger"></i> Đặt qua Messenger
                        </button>
                        <button onclick="datQuaChat('zalo')" class="btn-zalo" id="btnZalo">
                            <i class="bi bi-chat-dots-fill"></i> Đặt qua Zalo
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* Flatpickr dark mode */
    [data-theme="dark"] .flatpickr-calendar {
        background: var(--bg-card);
        border-color: var(--border);
        box-shadow: 0 8px 30px rgba(0,0,0,.4);
    }
    [data-theme="dark"] .flatpickr-months, [data-theme="dark"] .flatpickr-weekdays,
    [data-theme="dark"] span.flatpickr-weekday { background: var(--bg-card); color: var(--text-secondary); }
    [data-theme="dark"] .flatpickr-day { color: var(--text); }
    [data-theme="dark"] .flatpickr-day:hover { background: var(--bg-surface); border-color: var(--border); }
    [data-theme="dark"] .flatpickr-day.today { border-color: var(--primary); }
    [data-theme="dark"] .flatpickr-day.selected { background: var(--primary); border-color: var(--primary); }
    [data-theme="dark"] .flatpickr-day.flatpickr-disabled { color: var(--text-light); }
    [data-theme="dark"] .flatpickr-current-month .flatpickr-monthDropdown-months,
    [data-theme="dark"] .flatpickr-current-month input.cur-year { color: var(--text); }
    [data-theme="dark"] .flatpickr-months .flatpickr-prev-month svg,
    [data-theme="dark"] .flatpickr-months .flatpickr-next-month svg { fill: var(--text-secondary); }

    /* Flatpickr general style boost */
    .flatpickr-calendar { border-radius: 12px !important; font-family: var(--font) !important; }
    .flatpickr-day.selected, .flatpickr-day.selected:hover { 
        background: var(--primary) !important; 
        border-color: var(--primary) !important; 
    }
    .flatpickr-day.today { border-color: var(--primary) !important; color: var(--primary) !important; }

    /* Expired Slots */
    .slot-expired {
        opacity: 0.45;
        pointer-events: none;
        cursor: not-allowed;
    }
    .slot-expired .slot-price { text-decoration: line-through; color: var(--text-light) !important; }
    .slot-expired .slot-status { color: var(--danger) !important; font-weight: 600; }
</style>

@section Scripts {
<script>
var maPhong = @Model.MaPhong;
var linkMessenger = '@(Model.CaiDat.GetValueOrDefault("LinkMessenger",""))';
var linkZalo = '@(Model.CaiDat.GetValueOrDefault("LinkZalo",""))';
var tenPhong = '@Model.TenPhong';

var selectedSlots = [];

function chonKhungGio(el) {
    if (el.dataset.daDat === 'true') return;
    
    var id = parseInt(el.dataset.id);
    var gia = parseInt(el.dataset.gia);
    
    if (el.classList.contains('slot-selected')) {
        el.classList.remove('slot-selected');
        el.classList.add('slot-available');
        selectedSlots = selectedSlots.filter(s => s.id !== id);
    } else {
        el.classList.remove('slot-available');
        el.classList.add('slot-selected');
        selectedSlots.push({ id: id, gia: gia, ten: el.querySelector('.slot-name').textContent, thoiGian: el.querySelector('.slot-time').textContent });
    }
    
    capNhatTomTat();
}

function capNhatTomTat() {
    var slotsHtml = '';
    var tongTien = 0;
    var hiddenHtml = '';

    selectedSlots.forEach(function(s) {
        tongTien += s.gia;
        slotsHtml += '<div class="summary-slot-item"><span>' + s.ten + ' (' + s.thoiGian + ')</span><span>' + s.gia.toLocaleString('vi') + 'đ</span></div>';
        hiddenHtml += '<input type="hidden" name="DanhSachKhungGioId" value="' + s.id + '" />';
    });

    if (selectedSlots.length === 0) {
        slotsHtml = '<p class="text-muted">Chưa chọn khung giờ</p>';
    }

    document.getElementById('summarySlots').innerHTML = slotsHtml;
    document.getElementById('tongTien').textContent = tongTien.toLocaleString('vi') + 'đ';
    document.getElementById('hiddenKhungGio').innerHTML = hiddenHtml;
    document.getElementById('btnDatPhong').disabled = !canSubmit();
}

function doiNgay(ngay) {
    window.location.href = '/DatPhong?maPhong=' + maPhong + '&ngay=' + ngay;
}

function datQuaChat(loai) {
    var tenKhach = document.getElementById('inputTenKhach').value || 'Chưa nhập';
    var sdt = document.getElementById('inputSDT').value || 'Chưa nhập';
    var ngay = '@Model.NgayNhanPhong.ToString("dd-MM-yyyy")';
    var khungGio = selectedSlots.map(s => s.ten + ' (' + s.thoiGian + ')').join(', ') || 'Chưa chọn';

    var noiDung = 'Xin chào, tôi muốn đặt phòng:%0A' +
        '🏠 Phòng: ' + tenPhong + '%0A' +
        '📅 Ngày: ' + ngay + '%0A' +
        '⏰ Khung giờ: ' + khungGio + '%0A' +
        '👤 Tên: ' + tenKhach + '%0A' +
        '📱 SĐT: ' + sdt;

    if (loai === 'messenger') {
        window.open(linkMessenger + '?ref=' + encodeURIComponent(noiDung), '_blank');
    } else {
        window.open(linkZalo, '_blank');
    }
}

var isToday = '@Model.NgayNhanPhong.ToString("yyyy-MM-dd")' === new Date().toISOString().slice(0,10);

// Flatpickr date picker
flatpickr('#ngayDat', {
    locale: 'vn',
    dateFormat: 'd-m-Y',
    defaultDate: '@Model.NgayNhanPhong.ToString("yyyy-MM-dd")',
    minDate: 'today',
    maxDate: new Date().fp_incr(30),
    disableMobile: true,
    onChange: function(selectedDates, dateStr) {
        var d = selectedDates[0];
        var yyyy = d.getFullYear();
        var mm = String(d.getMonth() + 1).padStart(2, '0');
        var dd = String(d.getDate()).padStart(2, '0');
        doiNgay(yyyy + '-' + mm + '-' + dd);
    }
});

// Realtime check: auto-expire past time slots
function checkExpiredSlots() {
    if (!isToday) return;
    var now = new Date();
    var nowMinutes = now.getHours() * 60 + now.getMinutes();
    
    document.querySelectorAll('.timeline-slot').forEach(function(slot) {
        if (slot.classList.contains('slot-expired') || slot.classList.contains('slot-booked')) return;
        var gioBatDau = slot.dataset.gioBatDau;
        if (!gioBatDau) return;
        var parts = gioBatDau.split(':');
        var slotMinutes = parseInt(parts[0]) * 60 + parseInt(parts[1]);
        if (nowMinutes > slotMinutes) {
            slot.classList.remove('slot-available', 'slot-selected');
            slot.classList.add('slot-expired');
            slot.dataset.daDat = 'true';
            var statusEl = slot.querySelector('.slot-status');
            if (statusEl) statusEl.innerHTML = '<i class="bi bi-clock-history"></i> Đã qua giờ';
            statusEl.style.color = '#e53935';
            // Remove from selected if was selected
            var id = parseInt(slot.dataset.id);
            selectedSlots = selectedSlots.filter(function(s) { return s.id !== id; });
            capNhatTomTat();
        }
    });
}
setInterval(checkExpiredSlots, 60000);
checkExpiredSlots();

// === Validation: require slots + CCCD + checkbox ===
function canSubmit() {
    var hasSlots = selectedSlots.length > 0;
    var hasCccdTruoc = !!document.getElementById('cccdTruocInput').value;
    var hasCccdSau = !!document.getElementById('cccdSauInput').value;
    var checked = document.getElementById('chkXacNhan').checked;
    return hasSlots && hasCccdTruoc && hasCccdSau && checked;
}

function updateSubmitBtn() {
    document.getElementById('btnDatPhong').disabled = !canSubmit();
}

document.getElementById('chkXacNhan').addEventListener('change', updateSubmitBtn);

// === Upload CCCD ===
function uploadCCCD(input, inputId, previewId, statusId) {
    var file = input.files[0];
    if (!file) return;
    var status = document.getElementById(statusId);
    status.textContent = 'Đang tải...';
    status.style.color = '#667eea';

    var fd = new FormData();
    fd.append('file', file);

    fetch('/QuanTri/UploadHinhAnh', { method: 'POST', body: fd })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.success) {
                document.getElementById(inputId).value = d.filePath;
                var img = document.getElementById(previewId);
                img.src = d.filePath;
                img.style.display = 'block';
                status.textContent = '✅ Đã tải';
                status.style.color = '#2e7d32';
            } else {
                status.textContent = '❌ Lỗi';
                status.style.color = '#e53935';
            }
            updateSubmitBtn();
        });
}

// Form submit validation
document.getElementById('datPhongForm').addEventListener('submit', function(e) {
    if (!canSubmit()) {
        e.preventDefault();
        var msg = '';
        if (selectedSlots.length === 0) msg = 'Vui lòng chọn khung giờ.';
        else if (!document.getElementById('cccdTruocInput').value) msg = 'Vui lòng tải ảnh CCCD mặt trước.';
        else if (!document.getElementById('cccdSauInput').value) msg = 'Vui lòng tải ảnh CCCD mặt sau.';
        else if (!document.getElementById('chkXacNhan').checked) msg = 'Vui lòng xác nhận điều khoản.';
        if (typeof showWarning === 'function') showWarning('⚠️', msg);
        else alert(msg);
    }
});
</script>
}
