@model VeDatPhongViewModel
@{
    ViewData["Title"] = "Đặt phòng thành công";
    var thoiGianGiuPhong = Model.CaiDat.GetValueOrDefault("ThoiGianGiuPhong", "30");
    var qrThanhToan = Model.CaiDat.GetValueOrDefault("QrThanhToan", "");
    var thongTinChuyenKhoan = Model.CaiDat.GetValueOrDefault("ThongTinChuyenKhoan", "");
    var hotline = Model.CaiDat.GetValueOrDefault("Hotline", "");
}

<style>
    .tc-wrap { max-width: 560px; margin: 40px auto; padding: 0 16px; }

    .tc-card {
        background: #fff;
        border-radius: 24px;
        box-shadow: 0 8px 40px rgba(255,90,95,.12), 0 2px 8px rgba(0,0,0,.06);
        overflow: hidden;
        animation: slideUp .5s ease;
    }
    @@keyframes slideUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }

    /* Header gradient */
    .tc-header {
        background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 50%, #ffecd2 100%);
        padding: 36px 24px 28px;
        text-align: center;
        position: relative;
    }
    .tc-header::after {
        content: '';
        position: absolute; bottom: -1px; left: 0; right: 0;
        height: 28px;
        background: #fff;
        border-radius: 28px 28px 0 0;
    }
    .tc-icon {
        width: 72px; height: 72px;
        background: rgba(255,255,255,.85);
        border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 36px;
        margin-bottom: 12px;
        animation: bounce 1s ease infinite alternate;
    }
    @@keyframes bounce { 0%{transform:translateY(0)} 100%{transform:translateY(-6px)} }
    .tc-header h1 { font-size: 22px; font-weight: 700; color: #2d3436; margin: 0 0 4px; }
    .tc-header p { font-size: 14px; color: #636e72; margin: 0; }

    /* Body */
    .tc-body { padding: 4px 24px 28px; }

    /* Order summary mini card */
    .tc-order {
        background: #f8f9fa;
        border-radius: 14px;
        padding: 16px;
        margin-bottom: 20px;
        border: 1px dashed #dfe6e9;
    }
    .tc-order-row { display: flex; justify-content: space-between; padding: 5px 0; font-size: 14px; color: #636e72; }
    .tc-order-row strong { color: #2d3436; }
    .tc-order-total { display: flex; justify-content: space-between; padding: 10px 0 0; margin-top: 8px; border-top: 1px solid #dfe6e9; font-size: 18px; font-weight: 700; color: #ff5a5f; }

    /* Timer pill */
    .tc-timer {
        display: inline-flex; align-items: center; gap: 6px;
        background: linear-gradient(135deg, #fff3e0, #ffe0b2);
        color: #e65100;
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 13px; font-weight: 600;
        margin-bottom: 20px;
    }

    /* Payment section */
    .tc-pay {
        background: linear-gradient(135deg, #e8f5e9, #f1f8e9);
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
        border: 1px solid #c8e6c9;
    }
    .tc-pay-title { font-size: 16px; font-weight: 700; color: #2e7d32; margin: 0 0 14px; display: flex; align-items: center; gap: 8px; }
    .tc-qr-img { max-width: 200px; border-radius: 12px; border: 3px solid #fff; box-shadow: 0 2px 12px rgba(0,0,0,.1); }
    .tc-bank {
        background: #fff;
        border-radius: 12px;
        padding: 14px;
        margin-top: 14px;
        border: 1px solid #e8f5e9;
    }
    .tc-bank-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 6px 0;
        font-size: 14px;
        border-bottom: 1px dashed #f0f0f0;
    }
    .tc-bank-row:last-child { border-bottom: none; }
    .tc-bank-label { color: #888; font-size: 12px; }
    .tc-bank-value { color: #2d3436; font-weight: 600; font-size: 15px; }
    .tc-bank-copy {
        background: #e8f5e9; color: #2e7d32;
        border: none; border-radius: 6px;
        padding: 3px 10px; font-size: 12px; cursor: pointer;
        transition: all .2s;
    }
    .tc-bank-copy:hover { background: #c8e6c9; }
    .tc-transfer-note {
        background: #fff3e0;
        border-radius: 8px;
        padding: 10px 14px;
        margin-top: 12px;
        font-size: 13px;
        color: #e65100;
        display: flex; align-items: center; gap: 8px;
    }

    /* Upload section */
    .tc-upload {
        border: 2px dashed #b2dfdb;
        border-radius: 16px;
        padding: 24px;
        text-align: center;
        margin-bottom: 20px;
        transition: all .3s;
        cursor: pointer;
        background: #fafffe;
    }
    .tc-upload:hover { border-color: #4db6ac; background: #e0f2f1; }
    .tc-upload.dragging { border-color: #00897b; background: #b2dfdb; }
    .tc-upload-icon { font-size: 40px; color: #4db6ac; margin-bottom: 8px; }
    .tc-upload h4 { font-size: 15px; color: #2d3436; margin: 0 0 4px; font-weight: 600; }
    .tc-upload p { font-size: 12px; color: #999; margin: 0; }
    .tc-upload input[type="file"] { display: none; }
    .tc-upload-preview { max-width: 100%; max-height: 200px; border-radius: 12px; margin-top: 12px; display: none; }

    .tc-upload-done {
        background: #e8f5e9;
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        margin-bottom: 20px;
        display: none;
    }
    .tc-upload-done i { font-size: 40px; color: #2e7d32; }
    .tc-upload-done p { margin: 8px 0 0; color: #2e7d32; font-weight: 600; }

    .tc-upload-progress {
        display: none;
        margin-top: 12px;
    }
    .tc-progress-bar {
        height: 6px;
        background: #e0e0e0;
        border-radius: 3px;
        overflow: hidden;
    }
    .tc-progress-fill {
        height: 100%;
        background: linear-gradient(90deg, #4db6ac, #00897b);
        border-radius: 3px;
        width: 0%;
        transition: width .3s;
    }
    .tc-progress-text { font-size: 12px; color: #666; margin-top: 4px; }

    /* Buttons */
    .tc-actions { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
    .tc-btn {
        padding: 12px 24px; border-radius: 12px; font-size: 14px; font-weight: 600;
        text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
        transition: all .2s; border: none; cursor: pointer;
    }
    .tc-btn-primary { background: linear-gradient(135deg, #ff9a9e, #ff5a5f); color: #fff; box-shadow: 0 4px 12px rgba(255,90,95,.3); }
    .tc-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(255,90,95,.4); }
    .tc-btn-outline { background: #fff; color: #636e72; border: 1px solid #dfe6e9; }
    .tc-btn-outline:hover { background: #f8f9fa; }

    /* Contact */
    .tc-contact { text-align: center; font-size: 13px; color: #999; margin-top: 16px; }
    .tc-contact a { color: #ff5a5f; text-decoration: none; font-weight: 600; }
</style>

<section style="min-height:80vh; display:flex; align-items:center; background: linear-gradient(180deg, #ffecd2 0%, #fcf5f0 100%);">
    <div class="tc-wrap">
        <div class="tc-card">
            <!-- Header -->
            <div class="tc-header">
                @if (Model.DatPhong.TrangThai == "ChoXacNhan")
                {
                    <div class="tc-icon">⏳</div>
                    <h1>Đặt phòng thành công!</h1>
                    <p>Đơn <strong>@Model.DatPhong.MaDatPhong</strong> đang chờ xác nhận ✨</p>
                }
                else if (Model.DatPhong.TrangThai == "DaHetHan")
                {
                    <div class="tc-icon" style="filter:grayscale(1);">⏰</div>
                    <h1 style="color:#9e9e9e;">Đã hết hạn</h1>
                    <p style="color:#999;">Đơn <strong>@Model.DatPhong.MaDatPhong</strong> đã hết hạn sử dụng.</p>
                }
                else if (Model.DatPhong.TrangThai == "DaHuy")
                {
                    <div class="tc-icon" style="filter:grayscale(1);">🚫</div>
                    <h1 style="color:#e53935;">Đã hủy</h1>
                    <p style="color:#999;">Đơn <strong>@Model.DatPhong.MaDatPhong</strong> đã bị hủy.</p>
                }
                else
                {
                    <div class="tc-icon">🎉</div>
                    <h1>Đã xác nhận!</h1>
                    <p>Vé đã được gửi qua Email & Zalo 💌</p>
                }
            </div>

            <!-- Body -->
            <div class="tc-body">
                <!-- Order summary -->
                <div class="tc-order">
                    <div class="tc-order-row"><span>🏠 Phòng</span> <strong>@Model.Phong.TenPhong</strong></div>
                    <div class="tc-order-row"><span>📍 Địa chỉ</span> <strong>@Model.Phong.DiaChi</strong></div>
                    <div class="tc-order-row"><span>📅 Ngày</span> <strong>@Model.DatPhong.NgayNhanPhong.ToString("dd-MM-yyyy")</strong></div>
                    <div class="tc-order-row" style="flex-direction:column;gap:4px;">
                        <span>⏰ Khung giờ</span>
                        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:2px;">
                            @foreach (var ct in Model.DanhSachChiTiet)
                            {
                                <span style="background:linear-gradient(135deg,#fff3e0,#ffe0b2);padding:4px 10px;border-radius:8px;font-size:13px;font-weight:600;color:#e65100;">
                                    @ct.KhungGio?.BieuTuong @ct.KhungGio?.TenKhungGio
                                    (@ct.KhungGio?.GioBatDau.ToString("hh\\:mm")–@ct.KhungGio?.GioKetThuc.ToString("hh\\:mm"))
                                    — @ct.GiaApDung.ToString("N0")đ
                                </span>
                            }
                        </div>
                    </div>
                    <div class="tc-order-row"><span>👤 Khách</span> <strong>@Model.DatPhong.TenKhach</strong></div>
                    <div class="tc-order-total"><span>💰 Tổng tiền</span> <span>@Model.DatPhong.TongTien.ToString("N0")đ</span></div>
                </div>

                @if (Model.DatPhong.TrangThai == "ChoXacNhan")
                {
                    <!-- Timer countdown -->
                    <div style="text-align:center;">
                        <div class="tc-timer" id="timerPill" data-created="@Model.DatPhong.NgayDat.ToString("yyyy-MM-ddTHH:mm:ss")" data-minutes="@thoiGianGiuPhong">
                            <i class="bi bi-clock-history"></i>
                            <span id="countdownText">Đang tính...</span>
                        </div>
                    </div>

                    <!-- Payment info -->
                    @if (!string.IsNullOrEmpty(qrThanhToan) || !string.IsNullOrEmpty(thongTinChuyenKhoan))
                    {
                        <div class="tc-pay">
                            <div class="tc-pay-title"><i class="bi bi-wallet2"></i> Thanh toán chuyển khoản</div>

                            @if (!string.IsNullOrEmpty(qrThanhToan))
                            {
                                <div style="text-align:center;">
                                    <img src="@qrThanhToan" alt="QR Thanh toán" class="tc-qr-img" />
                                    <p style="font-size:12px;color:#666;margin:8px 0 0;">Quét mã QR để thanh toán nhanh 📱</p>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(thongTinChuyenKhoan))
                            {
                                <div class="tc-bank">
                                    @{
                                        var lines = thongTinChuyenKhoan.Split('\n');
                                        foreach (var line in lines)
                                        {
                                            var parts = line.Split(':', 2);
                                            if (parts.Length == 2)
                                            {
                                                <div class="tc-bank-row">
                                                    <div>
                                                        <div class="tc-bank-label">@parts[0].Trim()</div>
                                                        <div class="tc-bank-value" id="bv-@parts[0].Trim().Replace(" ","")">@parts[1].Trim()</div>
                                                    </div>
                                                    <button class="tc-bank-copy" onclick="copyText('@parts[1].Trim()')">
                                                        <i class="bi bi-clipboard"></i> Copy
                                                    </button>
                                                </div>
                                            }
                                        }
                                    }
                                </div>

                                <div class="tc-transfer-note">
                                    <i class="bi bi-info-circle-fill"></i>
                                    <span>Nội dung CK: <strong id="ckContent">@Model.DatPhong.MaDatPhong</strong>
                                        <button class="tc-bank-copy" onclick="copyText('@Model.DatPhong.MaDatPhong')" style="margin-left:6px;">
                                            <i class="bi bi-clipboard"></i>
                                        </button>
                                    </span>
                                </div>
                            }
                        </div>
                    }

                    <!-- Upload bill -->
                    <div id="uploadArea" class="tc-upload" onclick="document.getElementById('billInput').click();"
                         ondragover="event.preventDefault(); this.classList.add('dragging');"
                         ondragleave="this.classList.remove('dragging');"
                         ondrop="event.preventDefault(); this.classList.remove('dragging'); handleDrop(event);">
                        <div class="tc-upload-icon"><i class="bi bi-cloud-arrow-up"></i></div>
                        <h4>📸 Tải lên biên lai chuyển khoản</h4>
                        <p>Kéo thả hoặc bấm để chọn ảnh (JPG, PNG)</p>
                        <input type="file" id="billInput" accept="image/*" onchange="handleFileSelect(this)" />
                        <img id="previewImg" class="tc-upload-preview" />
                        <div id="uploadProgress" class="tc-upload-progress">
                            <div class="tc-progress-bar"><div id="progressFill" class="tc-progress-fill"></div></div>
                            <div class="tc-progress-text" id="progressText">Đang tải lên...</div>
                        </div>
                    </div>

                    <div id="uploadDone" class="tc-upload-done">
                        <i class="bi bi-check-circle-fill"></i>
                        <p>Đã tải lên biên lai thành công! ✅</p>
                        <p style="font-size:12px;color:#888;font-weight:normal;">Admin sẽ xác nhận đơn sau khi kiểm tra.</p>
                    </div>
                }

                <!-- Actions -->
                <div class="tc-actions">
                    <a href="/DatPhong/TraCuu?ma=@Model.DatPhong.MaDatPhong" class="tc-btn tc-btn-primary">
                        <i class="bi bi-search"></i> Tra cứu đơn
                    </a>
                    <a href="/" class="tc-btn tc-btn-outline">
                        <i class="bi bi-house-heart"></i> Về trang chủ
                    </a>
                </div>

                @if (!string.IsNullOrEmpty(hotline))
                {
                    <div class="tc-contact">
                        Cần hỗ trợ? Gọi <a href="tel:@hotline">@hotline</a> 💬
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
function copyText(text) {
    navigator.clipboard.writeText(text).then(function() {
        var toast = document.createElement('div');
        toast.textContent = '✅ Đã copy!';
        toast.style.cssText = 'position:fixed;bottom:20px;left:50%;transform:translateX(-50%);background:#2e7d32;color:#fff;padding:8px 20px;border-radius:20px;font-size:13px;z-index:9999;animation:slideUp .3s ease;';
        document.body.appendChild(toast);
        setTimeout(function() { toast.remove(); }, 1500);
    });
}

function handleDrop(e) {
    var file = e.dataTransfer.files[0];
    if (file && file.type.startsWith('image/')) {
        showPreview(file);
        uploadFile(file);
    }
}

function handleFileSelect(input) {
    var file = input.files[0];
    if (file) {
        showPreview(file);
        uploadFile(file);
    }
}

function showPreview(file) {
    var reader = new FileReader();
    reader.onload = function(e) {
        var img = document.getElementById('previewImg');
        img.src = e.target.result;
        img.style.display = 'block';
    };
    reader.readAsDataURL(file);
}

function uploadFile(file) {
    var formData = new FormData();
    formData.append('maDatPhong', '@Model.DatPhong.MaDatPhong');
    formData.append('billFile', file);

    var progress = document.getElementById('uploadProgress');
    var fill = document.getElementById('progressFill');
    var text = document.getElementById('progressText');
    progress.style.display = 'block';

    // Simulate progress
    var pct = 0;
    var interval = setInterval(function() {
        pct += Math.random() * 25;
        if (pct > 90) pct = 90;
        fill.style.width = pct + '%';
        text.textContent = 'Đang tải lên... ' + Math.round(pct) + '%';
    }, 200);

    fetch('/DatPhong/UploadMinhChung', { method: 'POST', body: formData })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            clearInterval(interval);
            fill.style.width = '100%';
            text.textContent = 'Hoàn tất!';
            if (d.success) {
                setTimeout(function() {
                    document.getElementById('uploadArea').style.display = 'none';
                    document.getElementById('uploadDone').style.display = 'block';
                }, 500);
            } else {
                text.textContent = 'Lỗi: ' + (d.message || 'Thử lại');
                text.style.color = '#e53935';
            }
        })
        .catch(function() {
            clearInterval(interval);
            text.textContent = 'Lỗi kết nối, vui lòng thử lại.';
            text.style.color = '#e53935';
        });
}

// ===== Countdown Timer =====
var timerEl = document.getElementById('timerPill');
if (timerEl) {
    var created = new Date(timerEl.dataset.created).getTime();
    var holdMinutes = parseInt(timerEl.dataset.minutes) || 30;
    var expireTime = created + holdMinutes * 60 * 1000;
    var cdText = document.getElementById('countdownText');

    function updateCountdown() {
        var now = Date.now();
        var remaining = expireTime - now;

        if (remaining <= 0) {
            cdText.innerHTML = '<strong>⚠️ Hết thời gian giữ phòng!</strong>';
            timerEl.style.background = 'linear-gradient(135deg, #ffebee, #ffcdd2)';
            timerEl.style.color = '#c62828';
            return;
        }

        var mins = Math.floor(remaining / 60000);
        var secs = Math.floor((remaining % 60000) / 1000);
        cdText.innerHTML = 'Giữ phòng còn <strong>' + mins + ':' + (secs < 10 ? '0' : '') + secs + '</strong> — vui lòng thanh toán';

        // Change color when < 5 minutes
        if (mins < 5) {
            timerEl.style.background = 'linear-gradient(135deg, #ffebee, #ffcdd2)';
            timerEl.style.color = '#c62828';
        }

        setTimeout(updateCountdown, 1000);
    }
    updateCountdown();
}
</script>
}
